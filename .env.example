# Flask Environment
FLASK_ENV=production

# Secret key for session management - CHANGE THIS TO A SECURE VALUE
SECRET_KEY=your-super-secret-key-change-this-to-something-long-and-random

# Database URL (can be PostgreSQL on Railway)
# For SQLite (local development):
# DATABASE_URL=sqlite:///elearning.db

# For PostgreSQL (Railway production):
# DATABASE_URL=postgresql://username:password@host:5432/database_name

# Railway will automatically provide DATABASE_URL if you add PostgreSQL service

# Application Settings
DEBUG=False
WORKERS=4
PYTHONUNBUFFERED=1
